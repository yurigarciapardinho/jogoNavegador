# Ambiente
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Banco PostgreSQL
DATABASE_URL="postgresql://usuario:senha@host:5432/database?schema=public&pgbouncer=true"
DIRECT_URL="postgresql://usuario:senha@host:5432/database?schema=public"

# Segurança
JWT_SECRET="troque-por-uma-chave-forte"

# CORS
CORS_ORIGIN="http://localhost:5173"

# Serviço opcional do Conselheiro/IA
# Opcional no alpha. Se ausente, apenas a rota /conselheiro retornará 503.
CONSELHEIRO_URL="http://localhost:3000/perguntar"
