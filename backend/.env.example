# Arquivo de configuração de exemplo para o backend
# Copie este arquivo para `.env` e substitua os valores pelos seus dados reais.
# ATENÇÃO: Nunca commite o arquivo `.env` no repositório.

# String de conexão PostgreSQL (exemplo Supabase com PgBouncer)
DATABASE_URL="postgresql://USER:SENHA@HOST:5432/BANCO?pgbouncer=true"

# Conexão direta com o banco (sem PgBouncer) — necessária para seed e migrations
DIRECT_URL="postgresql://USER:SENHA@HOST:5432/BANCO"

# Porta do servidor Fastify
PORT=8080

# URL do serviço de IA do Conselheiro
CONSELHEIRO_URL="http://localhost:3000/perguntar"

# Origens permitidas pelo CORS (use '*' apenas em desenvolvimento)
# Em produção, informe a URL exata do frontend, ex: https://meu-jogo.com
CORS_ORIGIN="*"
