# Arquivo de configuração de exemplo para o frontend
# Copie este arquivo para `.env` e substitua os valores pelos seus dados reais.
# ATENÇÃO: Nunca commite o arquivo `.env` no repositório.

# URL base da API do backend
VITE_API_URL="http://localhost:8080"

# ID da aldeia do jogador (obtido após rodar `npm run db:seed` no backend)
VITE_VILLAGE_ID="cole-aqui-o-id-da-aldeia"
