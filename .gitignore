# ─── Dependências ──────────────────────────────────────────────────────────────
node_modules/

# ─── Build e artefatos ─────────────────────────────────────────────────────────
dist/
build/
out/

# ─── Cache de ferramentas ──────────────────────────────────────────────────────
.vite/
.cache/
.parcel-cache/

# ─── Cobertura de testes ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ─── Arquivos de ambiente (nunca commitar segredos) ────────────────────────────
.env
.env.*
# Arquivos de exemplo são seguros — devem ser versionados
!*.example

# ─── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ─── Sistema Operacional ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editores ──────────────────────────────────────────────────────────────────
.idea/
.vscode/
.history/

# ─── Arquivos sensíveis avulsos ────────────────────────────────────────────────
*.pem
*.key
secrets.json
